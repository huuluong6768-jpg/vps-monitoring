# =============================================
# VPS Monitoring — Environment Variables
# =============================================
# This project uses a monorepo with 3 packages:
#   packages/api  — Express API server (port 4000)
#   packages/web  — Next.js dashboard UI (port 3000)
#   packages/shared — Shared models, DB, encryption
#
# Both API and Web need these env vars.
# Copy this file to .env in the project root.
# =============================================

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/vps-monitoring

# JWT secret (generate with: openssl rand -hex 64)
JWT_SECRET=replace-me-with-a-long-random-string-please-change-this

# Public URL where the dashboard is hosted
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API server port (Express backend)
API_PORT=4000

# API server URL (used by Next.js to proxy API calls)
API_URL=http://localhost:4000

# Web origins allowed by CORS (comma-separated)
WEB_ORIGINS=http://localhost:3000

# Optional: how many seconds before an agent is considered offline
AGENT_OFFLINE_AFTER_SECONDS=60

# Google Drive OAuth (for cloud backups)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# Encryption key for cloud provider credentials (defaults to JWT_SECRET if not set)
# BACKUP_ENCRYPTION_KEY=replace-me-with-a-long-random-string
