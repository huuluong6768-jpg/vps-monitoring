{
  "name": "vps-monitoring",
  "version": "1.0.0",
  "description": "Open-source VPS monitoring & management dashboard built with Next.js + MongoDB",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "packages/shared",
    "packages/api",
    "packages/web"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=@vps-monitoring/api",
    "dev:web": "npm run dev --workspace=@vps-monitoring/web",
    "build:shared": "npm run build --workspace=@vps-monitoring/shared",
    "build:api": "npm run build --workspace=@vps-monitoring/api",
    "build:web": "npm run build --workspace=@vps-monitoring/web",
    "build": "npm run build:shared && npm run build:api && npm run build:web",
    "start:api": "npm run start --workspace=@vps-monitoring/api",
    "start:web": "npm run start --workspace=@vps-monitoring/web",
    "lint": "npm run lint --workspace=@vps-monitoring/web"
  }
}
